generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma/client"
  engineType   = "client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  observations Observation[]
  successVault SuccessVault[]
}

model Observation {
  id           String       @id @default(uuid())
  userId       String
  situation    String
  trigger      String
  thoughts     String
  emotions     String
  actions      String
  consequences String
  createdAt    DateTime     @default(now())
  hypotheses   Hypothesis[]
  user         User         @relation(fields: [userId], references: [id])
}

model Hypothesis {
  id               String           @id @default(uuid())
  observationId    String
  explanation      String
  solution         String
  successCondition String
  failCondition    String
  preparation      String
  heuristic        String
  status           HypothesisStatus @default(TESTING)
  minDays          Int              @default(7)
  maxFailures      Int              @default(2)
  maxSkips         Int              @default(2)
  targetWinRate    Int              @default(80)
  createdAt        DateTime         @default(now())
  observation      Observation      @relation(fields: [observationId], references: [id])
  successVaults    SuccessVault[]
  trackingEntries  TrackingEntry[]
}

model TrackingEntry {
  id               String     @id @default(uuid())
  hypothesisId     String
  date             DateTime   @default(now())
  situationDetails String?
  attemptMade      Boolean
  isSuccess        Boolean?
  notes            String?
  isExternalFactor Boolean    @default(false)
  createdAt        DateTime   @default(now())
  hypothesis       Hypothesis @relation(fields: [hypothesisId], references: [id])
}

model SuccessVault {
  id            String     @id @default(uuid())
  userId        String
  hypothesisId  String
  heuristicText String
  createdAt     DateTime   @default(now())
  hypothesis    Hypothesis @relation(fields: [hypothesisId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
}

enum HypothesisStatus {
  TESTING
  SUCCESS
  REFUTED
}
